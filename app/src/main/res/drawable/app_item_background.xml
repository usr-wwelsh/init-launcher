<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Highlight: fills top-left edges (recessed look = reversed) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bevel_highlight" />
        </shape>
    </item>
    <!-- Shadow: covers everything except top+left 2dp strip -->
    <item android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bevel_shadow" />
        </shape>
    </item>
    <!-- Fill: inset 2dp all around -->
    <item android:left="2dp" android:top="2dp" android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_dark" />
        </shape>
    </item>
</layer-list>
