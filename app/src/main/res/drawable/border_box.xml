<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow: fills bottom-right edges -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bevel_shadow" />
        </shape>
    </item>
    <!-- Highlight: covers everything except bottom+right 2dp strip -->
    <item android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bevel_highlight" />
        </shape>
    </item>
    <!-- Fill: inset 2dp all around, revealing the bevel edges -->
    <item android:left="2dp" android:top="2dp" android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
        </shape>
    </item>
</layer-list>
