<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- === THEME: Flat mono === -->
    <!-- Change these to retheme the entire app -->

    <color name="background">#3B3E47</color>       <!-- Main background -->
    <color name="surface">#3B3E47</color>          <!-- Raised panel fill -->
    <color name="surface_dark">#3B3E47</color>     <!-- Recessed / item fill -->
    <color name="progress_track">#3B3E47</color>   <!-- Progress bar background -->

    <color name="bevel_highlight">#3B3E47</color>  <!-- Top-left bright edge -->
    <color name="bevel_shadow">#3B3E47</color>     <!-- Bottom-right dark edge -->

    <color name="text_primary">#B8B8B8</color>     <!-- Primary text / values -->
    <color name="text_label">#B8B8B8</color>       <!-- Section labels -->
    <color name="text_hint">#B8B8B8</color>        <!-- Placeholder / hint text -->

    <color name="accent_primary">#B8B8B8</color>   <!-- Clock, buttons, app names -->
    <color name="accent_secondary">#3B3E47</color> <!-- Dark accent -->
    <color name="border_color">#B8B8B8</color>     <!-- Border / title bar -->

    <color name="ram_bar">#B8B8B8</color>          <!-- RAM progress -->
    <color name="disk_bar">#B8B8B8</color>         <!-- Disk progress -->
    <color name="net_upload">#B8B8B8</color>       <!-- Network upload line -->
    <color name="net_download">#B8B8B8</color>     <!-- Network download line -->
    <color name="net_grid">#3B3E47</color>         <!-- Network graph grid -->

    <!-- Legacy aliases (layouts reference these) -->
    <color name="black">@color/background</color>
    <color name="neon_green">@color/accent_primary</color>
    <color name="neon_cyan">@color/text_label</color>
    <color name="white">@color/text_primary</color>
    <color name="red">@color/ram_bar</color>
    <color name="purple">@color/disk_bar</color>
    <color name="light_gray">@color/surface</color>
    <color name="dark_green">@color/accent_secondary</color>
    <color name="magenta">@color/accent_primary</color>
</resources>
